APP_NAME=供应链库存协同与智能补货管理系统
APP_ENV=dev
# Preferred primary database: OceanBase / MySQL-compatible.
DATABASE_URL=mysql+pymysql://root:your-password@127.0.0.1:2881/supply_chain?charset=utf8mb4
# Local fallback when OceanBase is unavailable.
SQLITE_FALLBACK_URL=sqlite:///./schema/supply_chain.db
DATABASE_CONNECT_TIMEOUT_SECONDS=3
EXAMPLE_DATA_DIR=./example
LLM_PROVIDER=rule
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
CACHE_TTL_SECONDS=60
